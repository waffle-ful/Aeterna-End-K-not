{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "EKMap editor: write maps into the user's Documents/EndKnot/EKMaps folder",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$DOCUMENT/EndKnot" },
        { "path": "$DOCUMENT/EndKnot/EKMaps" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$DOCUMENT/EndKnot/EKMaps/*" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$DOCUMENT/EndKnot/EKMaps/*" }
      ]
    }
  ]
}
